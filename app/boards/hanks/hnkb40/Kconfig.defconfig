if BOARD_HNKB40

config ZMK_KEYBOARD_NAME
    default "hnkb40"

# Use 'config' ONLY for the name. 
# Use 'select' or 'default' for existing drivers.
config SPI
    default y

config ZMK_GPIO_595
    default y

config ZMK_KSCAN_GPIO_MATRIX
    default y

if USB_DEVICE_STACK
config USB_NRFX
    default y
endif

config BT_CTLR
    default y

config ZMK_SLEEP
    default y

endif # BOARD_HNKB40