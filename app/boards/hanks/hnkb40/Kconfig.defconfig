if BOARD_HNKB40

config ZMK_KEYBOARD_NAME
    default "hnkb40"

# Set defaults for existing symbols (no type needed here)
config SPI
    default y

config ZMK_GPIO_595
    default y

if USB_DEVICE_STACK
config USB_NRFX
    default y
endif # USB_DEVICE_STACK

config BT_CTLR
    default y

endif # BOARD_HNKB40