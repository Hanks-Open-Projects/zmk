# Note: CONFIG_BOARD_HNKB40 and SOC configs are auto-set by the build system

# Enable MPU
CONFIG_ARM_MPU=y

CONFIG_PINCTRL=y

# enable GPIO
CONFIG_GPIO=y

# SPI and LED strip (WS2812 driver auto-selected by devicetree)
CONFIG_SPI=y
CONFIG_LED_STRIP=y

CONFIG_USE_DT_CODE_PARTITION=y
CONFIG_BUILD_OUTPUT_UF2=y

CONFIG_MPU_ALLOW_FLASH_WRITE=y
CONFIG_NVS=y
CONFIG_SETTINGS_NVS=y
CONFIG_FLASH=y
CONFIG_FLASH_PAGE_LAYOUT=y
CONFIG_FLASH_MAP=y

CONFIG_ZMK_RGB_UNDERGLOW=y
CONFIG_ZMK_RGB_UNDERGLOW_ON_START=y
CONFIG_ZMK_RGB_UNDERGLOW_EXT_POWER=y
CONFIG_ZMK_EXT_POWER=y

# TEST: Force white at full brightness
CONFIG_ZMK_RGB_UNDERGLOW_HUE_START=0
CONFIG_ZMK_RGB_UNDERGLOW_SAT_START=0
CONFIG_ZMK_RGB_UNDERGLOW_BRT_START=100
CONFIG_ZMK_RGB_UNDERGLOW_EFF_START=0

# USB logging for debugging
CONFIG_ZMK_USB_LOGGING=y

# SPI debug logging
CONFIG_SPI_LOG_LEVEL_DBG=y
CONFIG_LED_STRIP_LOG_LEVEL_DBG=y

# Reset settings on start (remove after first flash)
CONFIG_ZMK_SETTINGS_RESET_ON_START=y


CONFIG_ZMK_USB=y
CONFIG_ZMK_BLE=y

# Enable deep sleep with wake-on-keypress
CONFIG_ZMK_SLEEP=y

# Note: Using zmk,kscan-595a driver with GPIO bit-banging (luo_nice60 compatible)